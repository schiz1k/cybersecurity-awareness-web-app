{
  "name": "cybersecurity-awareness-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/src/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
